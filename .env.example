# ============================================================
# PJe Download — Environment Variables
# ============================================================
# Copy to .env and fill in values:
#   cp .env.example .env
# ============================================================

# ── MNI SOAP Authentication (required) ──
MNI_USERNAME=12345678900          # CPF sem pontos
MNI_PASSWORD=senha_mni
MNI_TRIBUNAL=TJES                 # TJES, TJES_2G, TJBA, TJBA_2G, TJCE, TRT17
MNI_TIMEOUT=60                    # Timeout SOAP em segundos
MNI_BATCH_SIZE=5                  # Docs por chamada SOAP na fase 2
MNI_ENABLED=true

# ── PJe / Worker ──
PJE_BASE_URL=https://pje.tjes.jus.br/pje
SESSION_TIMEOUT_MINUTES=60
MAX_DOCS_PER_SESSION=50
DOWNLOAD_DELAY_SECS=1.5
CONCURRENT_DOWNLOADS=3

# ── Infrastructure ──
REDIS_PASSWORD=pje_redis_2026
REDIS_URL=redis://:pje_redis_2026@redis:6379
DOWNLOAD_BASE_DIR=/data/downloads

# ── Ports ──
HEALTH_PORT=8006
DASHBOARD_PORT=8007
