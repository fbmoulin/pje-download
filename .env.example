# ============================================================
# PJe Download — Environment Variables
# ============================================================
# Copy to .env and fill in values:
#   cp .env.example .env
# ============================================================

# ── MNI SOAP Authentication (required) ──
MNI_USERNAME=12345678900          # CPF sem pontos
MNI_PASSWORD=senha_mni
MNI_TRIBUNAL=TJES                 # TJES, TJES_2G, TJBA, TJBA_2G, TJCE, TRT17
MNI_TIMEOUT=60                    # Timeout SOAP em segundos
MNI_BATCH_SIZE=5                  # Docs por chamada SOAP na fase 2
MNI_ENABLED=true
# MNI_PROXY=socks5://user:pass@host:port  # Proxy para contornar bloqueio de IP do tribunal

# ── PJe / Worker ──
PJE_BASE_URL=https://pje.tjes.jus.br/pje
SESSION_TIMEOUT_MINUTES=60
MAX_DOCS_PER_SESSION=50
DOWNLOAD_DELAY_SECS=1.5
CONCURRENT_DOWNLOADS=3

# ── Infrastructure ──
REDIS_PASSWORD=pje_redis_2026
REDIS_URL=redis://:pje_redis_2026@redis:6379
DOWNLOAD_BASE_DIR=/data/downloads

# ── Ports ──
HEALTH_PORT=8006
DASHBOARD_PORT=8007

# ── Audit sync → Railway Postgres (CNJ 615/2025 Phase 2, optional) ──
# Local /data/audit/*.jsonl remains source of truth; Railway is a redundant sink.
# Use an insert-only role (see migrations/001_audit_entries.sql).
# DATABASE_URL=postgres://audit_writer:secret@HOST.railway.app:5432/railway?sslmode=verify-full
# AUDIT_SYNC_ENABLED=false           # true to start the background syncer
# AUDIT_SYNC_INTERVAL_SECS=300       # tick every 5 min
# AUDIT_SYNC_BATCH_SIZE=100          # rows per insert batch
# AUDIT_SYNC_CATCHUP_DAYS=7          # scan this many days back on each tick
# AUDIT_SYNC_AUTO_MIGRATE=false      # flip true once to CREATE TABLE, then back to false
# AUDIT_SYNC_DRAIN_TIMEOUT_SECS=5.0  # max drain on SIGTERM
